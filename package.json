{
  "name": "heroine-pink",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "start": "cross-env ELEVENTY_IMG_PHASE=3 IS_LOCAL=false eleventy --serve --output=_site_web",
    "build": "npm run build:web",
    "clean:local": "node -e \"require('fs').rmSync('_site_local',{recursive:true,force:true})\"",
    "clean:web": "node -e \"require('fs').rmSync('_site_web',{recursive:true,force:true})\"",
    "build:local": "npm run clean:local && cross-env IS_LOCAL=true ELEVENTY_IMG_PHASE=3 eleventy --output=_site_local",
    "build:web": "npm run clean:web && cross-env IS_LOCAL=false ELEVENTY_IMG_PHASE=3 eleventy --output=_site_web"
  },
  "dependencies": {
    "slugify": "^1.6.6",
    "transliteration": "^2.6.0",
    "unidecode": "^1.1.0"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@11ty/eleventy-img": "^6.0.4",
    "cross-env": "^10.1.0"
  }
}
