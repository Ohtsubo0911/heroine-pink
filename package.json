{
  "name": "heroine-pink",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "start": "npm run build:web && eleventy --serve --ignore-initial --output=_site_web",
    "build": "npm run build:web",
    "build:local": "rm -rf _site_local && IS_LOCAL=true ELEVENTY_IMG_PHASE=3 eleventy --output=_site_local && node scripts/prune-optimized-images.cjs _site_local",
    "build:web": "rm -rf _site_web && ELEVENTY_IMG_PHASE=3 eleventy --output=_site_web && node scripts/prune-optimized-images.cjs _site_web"
  },
  "dependencies": {
    "slugify": "^1.6.6",
    "transliteration": "^2.6.0",
    "unidecode": "^1.1.0"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@11ty/eleventy-img": "^6.0.4"
  }
}
