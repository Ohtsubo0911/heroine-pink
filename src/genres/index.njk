---
layout: base.njk
permalink: "/genres/"
---

<section class="genres-index">

  <h1>ジャンル一覧</h1>

  <ul class="genres-grid">

    {% for genre in genresData %}
      {% set count = 0 %}

      {% for work in collections.works %}
        {% if (not work.data.draft)
              and work.data.genres
              and (genre.slug in work.data.genres) %}
          {% set count = count + 1 %}
        {% endif %}
      {% endfor %}

      <li>
        <a href="/genres/{{ genre.slug }}/">
          <h2>{{ genre.name }}（{{ count }}）</h2>
          <p>{{ genre.description }}</p>
        </a>
      </li>
    {% endfor %}
  </ul>

</section>
