<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }} {{actress}}｜魔法少女・セーラー・レンジャー・アメコミ・バトルスーツ・特撮ヒロイン作品紹介</title>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Review",
    "itemReviewed": {
      "@type": "Movie",
      "name": "{{ title }}",
      "image": "https://heroine.pink/{{ keyvisual }}",
      "dateCreated": "{{ release_date }}",
      "director": {
        "@type": "Person",
        "name": "{{ director }}"
      },
      "actor": [
        {% for actor in actress %}
          {
            "@type": "Person",
            "name": "{{ actor }}"
          }{% if not loop.last %},{% endif %}
        {% endfor %}
      ],
      "productionCompany": {
        "@type": "Organization",
        "name": "GIGA"
      },
      "duration": "PT{{duration}}M"
    },
    "reviewRating": {
      "@type": "Rating",
      "ratingValue": "{{ schema_rating }}",
      "bestRating": "5",
      "worstRating": "1"
    },
    "author": {
      "@type": "Organization",
      "name": "HEROINE PINK"
    },
    "publisher": {
      "@type": "Organization",
      "name": "HEROINE PINK"
    },
    "datePublished": "{{ date_published }}",
    "reviewBody": "{{ schema_review_body }}"
  }
</script>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=WDXL+Lubrifont+JP+N&display=swap" rel="stylesheet">
  <!-- Dela Gothic One を見出しの文字のみに限定して読み込む -->
  <link href="https://fonts.googleapis.com/css2?family=Dela+Gothic+One&display=swap&text={{ title }}" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Reggae+One&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css?family=M+PLUS+1p:400,700&display=swap&subset=japanese" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Kiwi+Maru&family=Shippori+Antique&display=swap" rel="stylesheet">

  {% if isLocal %}
    {# ローカル保存用：インライン化 #}
    <style>
        {% include "css/style.css" %}
        {% include "css/scenes.css" %}
        {% include "css/review.css" %}
        {% include "css/footer.css" %}
        {% include "css/navigation.css" %}
        {% include "css/backtotop.css" %}
    </style>
  {% else %}
    {# 開発・Web公開用：外部ファイル #}
    <link rel="stylesheet" href="{{ '/css/style.css' | url }}">
    <link rel="stylesheet" href="{{ '/css/scenes.css' | url }}">
    <link rel="stylesheet" href="{{ '/css/review.css' | url }}">
    <link rel="stylesheet" href="{{ '/css/footer.css' | url }}">
    <link rel="stylesheet" href="{{ '/css/navigation.css' | url }}">
    <link rel="stylesheet" href="{{ '/css/backtotop.css' | url }}">
    {% if bannervisual %}
    <link rel="stylesheet" href="{{ '/css/parallax-banner.css' | url }}">
    {% endif %}
    {% if see_also %}
    <link rel="stylesheet" href="{{ '/css/see-also.css' | url }}">
    {% endif %}
    
  {% endif %}

</head>

<body>
  <header>
    <div id="home">
      <p>
        <a href="{{ ('/') | relative(page) }}"><span class="title">HEROINE PINK</span><br>
          <span class="tagline">対ヒロイン研究分析機関</span></a>
      </p>
    </div>

    <!-- <div id="home">
      <p>
        <a href="{{ ('/') | relative(page) }}"><span class="title">TANITA</span><br>
          <span class="tagline">対応機器一覧</span></a>
      </p>
    </div> -->

    {% include "navigation.njk" %}
    
  </header>

  

  <main>
    <div id="title" style="background: {{keycolor}};">
      <h1>{{ title }}</h1>
    </div>

    <nav id="breadcrumb" aria-label="Breadcrumb">
      <ol>
        <li>
          <a href="{{ ('/') | relative(page) }}"><img alt="home" src="{{ ('/images/icon_home.svg') | relative(page) }}" /></a>
        </li>

        {% if genres %}
          {% set firstGenre = genres[0] %}

          {% set genreInfo = null %}
          {% for g in genresData %}
            {% if g.slug == firstGenre %}
              {% set genreInfo = g %}
            {% endif %}
          {% endfor %}

          {% if genreInfo %}
            <li>
              <a href="{{ ('/genres/' + firstGenre + '/') | relative(page) }}">
                {{ genreInfo.name }}
              </a>
            </li>
          {% endif %}
        {% endif %}

        <li aria-current="page">
          <span>{{ title }}</span>
        </li>
      </ol>
    </nav>


    <!-- <img id="keyvisual" src="/{{ keyvisual }}"
      alt="{{ title }} {% for name in actress %}{{ name }}{% if not loop.last %} {% endif %}{% endfor %}主演 特撮ヒロイン作品 {{ release_date }}" /> -->
    <img id="keyvisual" 
     src="{{ keyvisual | toWebp('main') | relative(page) }}"
     alt="{{ title }} {% for name in actress %}{{ name }}{% if not loop.last %} {% endif %}{% endfor %}主演 特撮ヒロイン作品 {{ release_date }}" />

    <div id="agenda">
      <ul class="clearfix">
        <li><a href="#story"><img src="{{ ('/images/icon_story.svg') | relative(page) }}"><br />STORY</a></li>
        <li><a href="#scenes"><img src="{{ ('/images/icon_scenes.svg') | relative(page) }}"><br />SCENES</a></li>
        <li><a href="#data"><img src="{{ ('/images/icon_data.svg') | relative(page) }}"><br />DATA</a></li>
        <li><a href="#review"><img src="{{ ('/images/icon_review.svg') | relative(page) }}"><br />REVIEW</a></li>
        <li><a href="#see-also"><img src="{{ ('/images/icon_see-also.svg') | relative(page) }}"><br />SEE ALSO</a></li>
      </ul>
    </div>

    <section id="story">
      <div id="lead">
        <h2><img src="{{ ('/images/icon_story.svg') | relative(page) }}"><br />STORY</h2>
        {{ story_lead | safe }}
      </div>
    </section>

    {% if isLocal %}
      <section id="scenes">
        <h2><img src="{{ ('/images/icon_scenes.svg') | relative(page) }}"><br />SCENES</h2>

        <p id="play"><a href="#" id="play-sequential">連続再生</a></p>

        {% for scene in scenes %}
        {% set current_video_src = scene.video_src or default_video_src %}

        <div class="scenes-detail">
          <div class="top">
            {% for bubble in scene.top %}
            <p class="{{ bubble.type }} {{ bubble.align }} tail-{{ bubble.tail }}">{{ bubble.text | safe }}</p>
            {% endfor %}
          </div>
          <div class="video-area">
            <video id="play-sequential" src="{{ current_video_src }}" playsinline muted {% if scene.start %}data-start="{{ scene.start }}" {% endif %} {% if scene.end %}data-end="{{ scene.end }}" {% endif %}></video>
          </div>
          <div class="bottom">
            {% for bubble in scene.bottom %}
            <p class="{{ bubble.type }} {{ bubble.align }} tail-{{ bubble.tail }}">{{ bubble.text | safe }}</p>
            {% endfor %}
          </div>
        </div>
        {% endfor %}
      </section>
    {% else %}
      <section id="scenes" class="image-scenes">
        <h2><img src="{{ ('/images/icon_scenes.svg') | relative(page) }}"><br />SCENES</h2>

        {% set image_scenes = scenes_img or [] %}
        {% for scene in image_scenes %}
        {% set current_img_src = (scene.img or scene.img_src or default_img_src) | replace('{{ work_code }}', work_code) %}

        <div class="scenes-detail">
          <div class="top">
            {% for bubble in scene.top %}
            <p class="{{ bubble.type }} {{ bubble.align }} tail-{{ bubble.tail }}">{{ bubble.text | safe }}</p>
            {% endfor %}
          </div>
          <div class="img-area">
            <img src="{{ current_img_src | toWebp('scene') | relative(page) }}" />
          </div>
          <div class="bottom">
            {% for bubble in scene.bottom %}
            <p class="{{ bubble.type }} {{ bubble.align }} tail-{{ bubble.tail }}">{{ bubble.text | safe }}</p>
            {% endfor %}
          </div>
        </div>
        {% endfor %}
      </section>
    {% endif %}

    {% if not isLocal and bannervisual %}
    <div class="scroll-container" id="parallax-section">
      <div class="sticky-wrapper">
        <a href="{{ affiliate_url }}" target="_blank" rel="noopener noreferrer">
          <img src="{{ bannervisual | toWebp('banner') | relative(page) }}" alt="Parallax Image" class="sliding-item">
          <div class="red-btn">FANZAで本編を見る</div>
        </a>
      </div>
    </div>
    {% endif %}

    <section id="data" class="clearfix" style="background: {{keycolor}};">
      <div>

        <h2><img src="{{ ('/images/icon_data.svg') | relative(page) }}"><br />DATA</h2>

        <p>作品番号：{{ work_code }}</p>
        <p>出演女優：
          {% for name in actress %}
          {% set slug = name | getActressSlug %}
          <a href="/actresses/{{ slug }}/">{{ name }}</a>{% if not loop.last %} {% endif %}
          {% endfor %}
        </p>
        <p>監督：<a href="/directors/{{ director | getDirectorSlug }}/">{{ director }}</a></p>
        <p>収録時間：{{ duration }}分</p>
        <p>DVDリリース日：{{ release_date }}</p>
        <p>シチュエーション:
          {% for tag in tags %}
          <a href="/tags/{{ tag }}/">{{ tagsData[tag].name }}</a>
          {% if not loop.last %} {% endif %}
          {% endfor %}
        </p>

      </div>

    </section>

    <section id="review" class="talkcss">

      <h2><img src="{{ ('/images/icon_review.svg') | relative(page) }}"><br />REVIEW</h2>

      {# レビュアーの紹介パート #}
      {% for id, reviewer in review.reviewers %}
      <i class="{{ id }} left icon named introduction"></i>
      <p>{{ reviewer.description }}</p>
      {% endfor %}

      {# 各分析セクションをループ #}
      {% for section in review.sections %}
      <h3>{{ section.title }}</h3>

      {# 各セクション内の対話をループ #}
      {% for chat in section.dialogue %}
      {# speaker ID（例: "judge"）を使って、レビュアーの位置（例: "left"）を取得 #}
      {% set speaker_id = chat.speaker %}
      {% set speaker_position = review.reviewers[speaker_id].position %}

      <i class="{{ speaker_id }} {{ speaker_position }} icon named"></i>
      <p>{{ chat.text | safe }}</p>
      {% endfor %}
      {% endfor %}

    </section>

    {% if see_also and see_also.length > 0 %}
    <section id="see-also" class="clearfix" >

      <h2><img src="{{ ('/images/icon_see-also.svg') | relative(page) }}"><br />SEE ALSO</h2>
        <ul>
          {% for item in see_also %}
          <li><a href="{{ item.url | relative(page) }}">
            <img src="{% if page.data | isPublic(publishTarget) %}{{ item.img | toWebp('main') | relative(page) }}{% else %}{{ item.img | relative(page) }}{% endif %}" />
          </a></li>
          {% endfor %}
        </ul>

    </section>
    {% endif %}

  </main>

  {% if not isLocal and bannervisual %}
  <div class="scroll-container" id="parallax-section">
    <div class="sticky-wrapper">
      <a href="{{ affiliate_url }}" target="_blank" rel="noopener noreferrer">
        <img src="{% if page.data | isPublic(publishTarget) %}{{ bannervisual | toWebp('banner') | relative(page) }}{% else %}{{ bannervisual | relative(page) }}{% endif %}" alt="Parallax Image" class="sliding-item reverse">
        <div class="red-btn">FANZAで本編を見る</div>
      </a>
    </div>
  </div>
  {% endif %}

  {% include "backtotop.njk" %}

  <footer id="footer" style="background: {{keycolor}};">
    <ul>
      <li><a href="{{ ('/about/') | relative(page) }}">ABOUT US</a></li>
      <li><a href="{{ ('/privacy/') | relative(page) }}">PRIVACY POLICY</a></li>
    </ul>
    <p><a href="{{ ('/') | relative(page) }}">&copy; HROINE PINK <span id="current-year">2025</span></a></p>
  </footer>

  {% if isLocal %}
    {# ローカル保存用：インライン化 #}
    <script>
        {% include "js/scenes.js" %}
        {% include "js/navigation.js" %}
        {% include "js/footer.js" %}
        {% include "js/backtotop.js" %}
        {% include "js/smooth-scroll.js" %}
    </script>
    {% else %}
        {# 開発・Web公開用：外部ファイル #}
        <script src="{{ '/js/scenes.js' | url }}"></script>
        <script src="{{ '/js/navigation.js' | url }}"></script>
        <script src="{{ '/js/footer.js' | url }}"></script>
        <script src="{{ '/js/backtotop.js' | url }}"></script>
        <script src="{{ '/js/smooth-scroll.js' | url }}"></script>
  {% endif %}

</body>

</html>