<div class="site-header">

  <button class="nav-toggle" aria-label="Open Navigation">
    <img src="{{ ('/images/icon_bars.svg') | relative(page) }}">
  </button>

  <nav class="slide-nav">
    <ul>

      <li class="list-home"">
          <a href="{{ ('/') | relative(page) }}">
            <!-- <img src="/images/icon_home.svg" alt="home" /> -->
            <img src="{{ ('/images/icon_home.svg') | relative(page) }}" alt="home" />
          </a>
        </li>

      {% for genre in genresData %}
        <li>
          <!-- <a href="./genres/{{ genre.slug }}/index.html"> -->
          <a href="{{ ('/genres/' + genre.slug + '/') | relative(page) }}">
            {{ genre.name }}
          </a>
        </li>
      {% endfor %}
    </ul>

    <ul>

      <!-- 女優・監督一覧への簡易リンク -->
      <li><a href="{{ ('/actresses/') | relative(page) }}">女優一覧</a></li>
